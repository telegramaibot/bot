# === MODIFIED ===
# Telegram UserBot (https://my.telegram.org)
API_ID=
API_HASH=
PHONE_NUMBER=+998901234567
SESSION_NAME=userbot_session
# Recommended for Railway/non-interactive deploy
# SESSION_STRING=

# Telegram Control Bot (https://t.me/BotFather)
BOT_TOKEN=

# Owner
OWNER_ID=
COMMAND_PREFIX=.

# Auth
ADMIN_LOGIN=admin
ADMIN_PASSWORD=changeme123
JWT_SECRET=supersecretkey123
SESSION_EXPIRE_HOURS=24

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Features
AUTO_RESPOND_CHATS=
MONITOR_KEYWORDS=dataset,excel,report,loyiha,tender,shartnoma

# Single log channel — ALL alerts, briefings and daily reports go here
LOG_CHANNEL_ID=

# Ghost mode
GHOST_MODE=true
MIN_DELAY=2
MAX_DELAY=6
READ_DELAY_MIN=30
READ_DELAY_MAX=120

# DB — stored on Railway persistent volume mounted at /data
# Add a volume in Railway dashboard and mount it at /data
DATABASE_PATH=/data/userbot.db
